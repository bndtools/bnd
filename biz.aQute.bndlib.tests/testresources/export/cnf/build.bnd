########################
## BUILD SETTINGS ##
########################
## Java Compiler Options
#java:                  java
#javac:                 javac
javac.source:           17
javac.target:           17
javac.compliance:       17
javac.debug:            on
-noimportjava: true

# This build requires newer Bnd features
-require-bnd: "(version>=7.2.0)"

# git properties
git-sha-short: ${system-allow-fail;git describe --dirty --always --abbrev=9}
git-sha:       ${system-allow-fail;git rev-list -1 --no-abbrev-commit HEAD}

# This is the version to baseline this build against. 
# see /cnf/ext/repositories.bnd and /cnf/ext/gav_99_baseline.mvn
base.version:     0.1.2
Bundle-Version:   ${base.version}.${tstamp}-SNAPSHOT

# -snapshot unset (commented out) is a snapshot build. (e.g. 1.0.0-SNAPSHOT)
# -snapshot set to a value (e.g. RC1) is a release build with the value as the Maven version qualifier. (e.g. 0.1.0-RC1)
# -snapshot set to the empty string is a release build with no Maven version qualifier. (e.g. 0.1.0)
-snapshot:

# Maven info. The maven artifactId defaults to Bundle-SymbolicName
-groupid:               io.klib.eval
-pom:                   version=${if;${def;-snapshot};${versionmask;===;${@version}}-${def;-snapshot};${versionmask;===s;${@version}}}
-maven-release:         pom

gpg: gpg --homedir ${def;USERHOME;~}/.gnupg --pinentry-mode loopback

# Don't baseline Bundle-Version
-diffignore:  Bundle-Version

Automatic-Module-Name:  ${def;bsn}
Bundle-Vendor:          bndtools.org

-make: (*).(jar);type=bnd; recipe="bnd/$1.bnd"
-reproducible: true

-plugin \
    aQute.p2.export.P2Exporter
